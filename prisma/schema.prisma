generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  VOLUNTARIO
  ENTIDAD
  ADMIN
}

enum EntityValidationStatus {
  PENDIENTE
  VERIFICADA
  RECHAZADA
  SUSPENDIDA
}

enum EventPublicationStatus {
  ACTIVO
  RETIRADO
}

model SystemCheck {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id                  Int                    @id @default(autoincrement())
  firstName           String
  lastName            String
  email               String                 @unique
  phone               String?
  passwordHash        String
  role                UserRole               @default(VOLUNTARIO)
  entity              Entity?
  entitySubscriptions EntitySubscription[]
  eventRegistrations  EventRegistration[]
  receivedNotifications InternalNotification[] @relation("NotificationRecipient")
  actedNotifications    InternalNotification[] @relation("NotificationActor")
  adminActionLogs     AdminActionLog[]
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
}

model Entity {
  id                  Int                    @id @default(autoincrement())
  organizationName    String
  legalName           String
  taxId               String                 @unique
  contactEmail        String
  contactPhone        String
  city                String
  address             String
  latitude            Decimal?               @db.Decimal(9, 6)
  longitude           Decimal?               @db.Decimal(9, 6)
  normalizedAddress   String?
  description         String
  supportingInfo      String?
  validationStatus    EntityValidationStatus @default(PENDIENTE)
  requestedByUser     User                   @relation(fields: [requestedByUserId], references: [id])
  requestedByUserId   Int                    @unique
  adminActionLogs     AdminActionLog[]
  events              Event[]
  subscriptions       EntitySubscription[]
  notifications       InternalNotification[]
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
}

model Event {
  id                Int                    @id @default(autoincrement())
  title             String
  description       String
  city              String
  address           String
  latitude          Decimal?               @db.Decimal(9, 6)
  longitude         Decimal?               @db.Decimal(9, 6)
  normalizedAddress String?
  startsAt          DateTime
  totalSlots        Int
  publicationStatus EventPublicationStatus @default(ACTIVO)
  entity            Entity                 @relation(fields: [entityId], references: [id])
  entityId          Int
  registrations     EventRegistration[]
  notifications     InternalNotification[]
  adminActionLogs   AdminActionLog[]
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
}

model EntitySubscription {
  id              Int      @id @default(autoincrement())
  volunteerUser   User     @relation(fields: [volunteerUserId], references: [id])
  volunteerUserId Int
  entity          Entity   @relation(fields: [entityId], references: [id])
  entityId        Int
  createdAt       DateTime @default(now())

  @@unique([volunteerUserId, entityId])
}

model EventRegistration {
  id              Int      @id @default(autoincrement())
  volunteerUser   User     @relation(fields: [volunteerUserId], references: [id])
  volunteerUserId Int
  event           Event    @relation(fields: [eventId], references: [id])
  eventId         Int
  createdAt       DateTime @default(now())

  @@unique([volunteerUserId, eventId])
}

model InternalNotification {
  id              Int      @id @default(autoincrement())
  recipientUser   User     @relation("NotificationRecipient", fields: [recipientUserId], references: [id])
  recipientUserId Int
  actorUser       User?    @relation("NotificationActor", fields: [actorUserId], references: [id])
  actorUserId     Int?
  entity          Entity   @relation(fields: [entityId], references: [id])
  entityId        Int
  event           Event?   @relation(fields: [eventId], references: [id])
  eventId         Int?
  type            String
  title           String
  message         String
  isRead          Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model AdminActionLog {
  id            Int                    @id @default(autoincrement())
  action        String
  fromStatus    EntityValidationStatus?
  toStatus      EntityValidationStatus?
  notes         String?
  adminUser     User                   @relation(fields: [adminUserId], references: [id])
  adminUserId   Int
  entity        Entity?                @relation(fields: [entityId], references: [id])
  entityId      Int?
  event         Event?                 @relation(fields: [eventId], references: [id])
  eventId       Int?
  createdAt     DateTime               @default(now())
}
