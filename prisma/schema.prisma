generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  VOLUNTARIO
  ENTIDAD
  ADMIN
}

enum EntityValidationStatus {
  PENDIENTE
  VERIFICADA
  RECHAZADA
  SUSPENDIDA
}

model SystemCheck {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           Int      @id @default(autoincrement())
  firstName    String
  lastName     String
  email        String   @unique
  phone        String?
  passwordHash String
  role         UserRole @default(VOLUNTARIO)
  entity       Entity?
  adminActionLogs AdminActionLog[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Entity {
  id                 Int                    @id @default(autoincrement())
  organizationName   String
  legalName          String
  taxId              String                 @unique
  contactEmail       String
  contactPhone       String
  city               String
  address            String
  description        String
  supportingInfo     String?
  validationStatus   EntityValidationStatus @default(PENDIENTE)
  requestedByUser    User                   @relation(fields: [requestedByUserId], references: [id])
  requestedByUserId  Int                    @unique
  adminActionLogs    AdminActionLog[]
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
}

model AdminActionLog {
  id            Int                    @id @default(autoincrement())
  action        String
  fromStatus    EntityValidationStatus
  toStatus      EntityValidationStatus
  notes         String?
  adminUser     User                   @relation(fields: [adminUserId], references: [id])
  adminUserId   Int
  entity        Entity                 @relation(fields: [entityId], references: [id])
  entityId      Int
  createdAt     DateTime               @default(now())
}
