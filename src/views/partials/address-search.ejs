<div class="address-search" data-address-search data-address-target="#address">
  <h2><%= typeof title !== "undefined" ? title : "Buscar direccion de Madrid" %></h2>
  <label for="<%= fieldPrefix %>AddressSearch">Buscar direccion</label>
  <div class="address-search-controls">
    <input
      id="<%= fieldPrefix %>AddressSearch"
      type="text"
      data-address-search-input
      placeholder="Ej. Calle Mayor 10, Madrid"
    />
    <button class="address-search-button" type="button" data-address-search-button>
      Buscar direccion
    </button>
  </div>
  <p class="field-help">
    Selecciona una sugerencia para guardar la direccion y sus coordenadas.
  </p>
  <div class="address-search-status" data-address-search-status aria-live="polite"></div>
  <div class="address-search-results" data-address-search-results></div>

  <input type="hidden" name="latitude" data-address-latitude value="<%= formData.latitude || "" %>" />
  <input type="hidden" name="longitude" data-address-longitude value="<%= formData.longitude || "" %>" />
  <input type="hidden" name="normalizedAddress" data-address-normalized value="<%= formData.normalizedAddress || "" %>" />
  <% if (typeof includeAddressHidden !== "undefined" && includeAddressHidden) { %>
    <input id="address" name="address" type="hidden" value="<%= formData.address || "" %>" />
  <% } %>

  <% if (formData.normalizedAddress) { %>
    <p class="field-help" data-address-selected>
      Direccion seleccionada: <%= formData.normalizedAddress %>
    </p>
  <% } else { %>
    <p class="field-help" data-address-selected></p>
  <% } %>

  <% if (errors.latitude) { %><p class="field-error"><%= errors.latitude %></p><% } %>
  <% if (errors.longitude) { %><p class="field-error"><%= errors.longitude %></p><% } %>
  <% if (errors.normalizedAddress) { %><p class="field-error"><%= errors.normalizedAddress %></p><% } %>
  <% if (errors.coordinates) { %><p class="field-error"><%= errors.coordinates %></p><% } %>
</div>
