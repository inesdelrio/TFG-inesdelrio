<section class="status-card map-shell">
  <% if (markers.length === 0) { %>
    <div class="map-empty-state">
      <strong>Sin ubicaciones disponibles.</strong>
      <p><%= emptyMessage %></p>
    </div>
  <% } %>

  <div class="map-content-grid">
    <div class="map-frame">
      <div
        id="volunred-map"
        class="map-container"
        data-empty-message="<%= emptyMessage %>"
        aria-label="<%= mapLabel %>"
      ></div>
    </div>

    <aside class="map-side-panel" data-map-side-panel>
      <section class="map-events-list-section">
        <div class="map-side-panel-header">
          <h2>Eventos en el mapa</h2>
          <p>Selecciona un evento para localizarlo en el mapa.</p>
        </div>
        <div class="map-event-list" data-map-events-list data-map-event-list></div>
      </section>

      <section class="map-selected-section" data-selected-map-item>
        <h3>Evento seleccionado</h3>
        <div class="map-selected-detail" data-map-selected-detail>
          <p>Selecciona un evento para ver su información.</p>
        </div>
      </section>
    </aside>
  </div>

  <script type="application/json" id="map-markers-json"><%- JSON.stringify(markers).replace(/</g, "\\u003c") %></script>
</section>

<script
  src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
  integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
  crossorigin=""
></script>
<script src="/js/map-view.js"></script>
