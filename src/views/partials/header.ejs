<header class="site-header">
  <div class="container">
    <a class="brand" href="/" aria-label="VolunRed">
      <img src="/img/brand/volunred-logo-horizontal.png" alt="VolunRed" />
    </a>
    <nav class="site-nav">
      <a href="/">Inicio</a>
      <% if (currentUser) { %>
        <% if (currentUser.role === "VOLUNTARIO") { %>
          <div class="nav-dropdown">
            <button class="nav-dropdown-toggle" type="button" aria-haspopup="true">
              Eventos
              <span aria-hidden="true">▼</span>
            </button>
            <div class="nav-dropdown-menu">
              <a href="/eventos">Ver eventos</a>
              <a href="/eventos/mapa">Mapa</a>
              <a href="/voluntariado/calendario">Calendario</a>
            </div>
          </div>
          <a href="/notificaciones">Notificaciones</a>
          <a href="/voluntariado/historial">Historial</a>
          <a href="/voluntariado/perfil">Perfil</a>
        <% } %>
        <% if (currentUser.role === "ENTIDAD") { %>
          <a href="/eventos">Eventos</a>
          <a href="/entidad/mapa">Mapa</a>
          <a href="/entidad/calendario">Calendario</a>
          <a href="/notificaciones">Notificaciones</a>
          <a href="/entidad/historial">Historial</a>
          <a href="/entidad/perfil">Perfil</a>
        <% } %>
        <% if (currentUser.role === "ADMIN") { %>
          <a href="/eventos">Eventos</a>
          <a href="/admin/area">Panel admin</a>
          <a href="/admin/mapa">Mapa</a>
          <a href="/admin/perfil">Perfil</a>
        <% } %>
      <% } else { %>
        <a href="/eventos">Eventos</a>
        <a href="/registro">Registro</a>
        <a href="/login">Iniciar sesion</a>
      <% } %>
    </nav>
  </div>
</header>
