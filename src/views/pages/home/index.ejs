<%- include("../../partials/head") %>
<%- include("../../partials/header") %>

<main class="container hero">
  <section class="hero-copy">
    <span class="eyebrow">Estado actual</span>
    <h1>Plataforma base de voluntariado ya operativa</h1>
    <p>
      La aplicacion ya arranca con Node.js, Express y EJS, conecta con PostgreSQL
      mediante Prisma, permite registro, login, alta y verificacion de entidades,
      perfiles editables y publicacion inicial de eventos.
    </p>

    <div class="status-grid">
      <article class="status-card">
        <h2>Servidor</h2>
        <p>Ruta principal renderizada con EJS.</p>
      </article>

      <article class="status-card">
        <h2>Static assets</h2>
        <p>CSS y JavaScript servidos desde la carpeta <code>public/</code>.</p>
      </article>

      <article class="status-card">
        <h2>Prisma</h2>
        <p>Cliente configurado, migraciones aplicadas y conexion operativa con PostgreSQL.</p>
      </article>

      <article class="status-card">
        <h2>Eventos</h2>
        <p>Las entidades verificadas ya pueden publicar actividades en el listado publico.</p>
      </article>
    </div>

    <% if (dbStatus) { %>
      <div class="db-status <%= dbStatus.ok ? "success" : "error" %>">
        <strong><%= dbStatus.ok ? "Base de datos disponible." : "Base de datos no disponible." %></strong>
        <p><%= dbStatus.message %></p>
      </div>
    <% } %>
  </section>
</main>

<%- include("../../partials/footer") %>
