<%- include("../../partials/head") %>
<%- include("../../partials/header") %>

<main class="container dashboard-page">
  <section class="dashboard-hero">
    <h1>Notificaciones</h1>
  </section>

  <% if (infoMessage) { %>
    <div class="feedback-banner success">
      <strong>Estado actualizado.</strong>
      <p><%= infoMessage %></p>
    </div>
  <% } %>

  <section class="event-list">
    <% if (notifications.length === 0) { %>
      <article class="status-card">
        <h2>Sin notificaciones</h2>
        <p>
          <%= currentUser.role === "ENTIDAD"
            ? "Todavia no hay actividad nueva en tus eventos."
            : "Todavia no tienes avisos de entidades seguidas." %>
        </p>
      </article>
    <% } %>

    <% notifications.forEach((notification) => { %>
      <article class="status-card notification-card <%= notification.isRead ? "notification-card-read" : "notification-card-unread" %>">
        <div class="notification-card-header">
          <h2><%= notification.title %></h2>
          <div class="notification-card-controls">
            <form
              class="inline-form notification-delete-form"
              action="/notificaciones/<%= notification.id %>/eliminar"
              method="post"
            >
              <button
                class="notification-trash-button"
                type="submit"
                aria-label="Eliminar notificación"
                title="Eliminar notificación"
              >
                <svg
                  aria-hidden="true"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M4 7h16" />
                  <path d="M9 7V4h6v3" />
                  <path d="M6.5 7l1 13h9l1-13" />
                  <path d="M10 11v5" />
                  <path d="M14 11v5" />
                </svg>
              </button>
            </form>
            <span class="notification-state"><%= notification.isRead ? "Leida" : "Nueva" %></span>
          </div>
        </div>

        <p><%= notification.message %></p>
        <% if (currentUser.role === "VOLUNTARIO") { %>
          <p><strong>Entidad:</strong> <%= notification.entity.organizationName %></p>
        <% } %>
        <p><strong>Fecha:</strong> <%= new Date(notification.createdAt).toLocaleString("es-ES") %></p>

        <div class="event-actions">
          <% if (notification.event) { %>
            <form class="inline-form" action="/notificaciones/<%= notification.id %>/abrir" method="post">
              <button class="secondary-link link-button" type="submit">Ver actividad</button>
            </form>
          <% } %>

          <% if (!notification.isRead) { %>
            <form class="inline-form" action="/notificaciones/<%= notification.id %>/leida" method="post">
              <button class="primary-button" type="submit">Marcar como leida</button>
            </form>
          <% } else { %>
            <form class="inline-form" action="/notificaciones/<%= notification.id %>/no-leida" method="post">
              <button class="primary-button" type="submit">Marcar como no leida</button>
            </form>
          <% } %>

        </div>
      </article>
    <% }) %>
  </section>

  <dialog class="confirmation-modal" data-notification-delete-modal>
    <div class="confirmation-modal-content">
      <h2>¿Quieres borrar esta notificación?</h2>
      <p>Esta acción no se puede deshacer.</p>
      <div class="confirmation-modal-actions">
        <button class="outline-button" type="button" data-notification-delete-cancel>Cancelar</button>
        <button class="danger-button" type="button" data-notification-delete-confirm>Eliminar</button>
      </div>
    </div>
  </dialog>
</main>

<%- include("../../partials/footer") %>
