<%- include("../../partials/head") %>
<%- include("../../partials/header") %>

<main class="container auth-page">
  <section class="auth-shell entity-shell">
    <div class="auth-intro">
      <h1>Registro de entidad</h1>
      <p>
        Crea la cuenta responsable y registra los datos de tu entidad. La
        solicitud quedara pendiente hasta que un administrador la valide.
      </p>
    </div>

    <div class="auth-card">
      <% if (Object.keys(errors).length > 0) { %>
        <div class="feedback-banner error">
          <strong>Revisa el formulario.</strong>
          <p>Hay campos con errores que impiden enviar la solicitud.</p>
        </div>
      <% } %>

      <form class="auth-form" action="/entidades/registro" method="post" novalidate>
        <h2>Responsable de la cuenta</h2>

        <div class="form-row">
          <label for="firstName">Nombre</label>
          <input id="firstName" name="firstName" type="text" required value="<%= formData.firstName %>" />
          <% if (errors.firstName) { %><p class="field-error"><%= errors.firstName %></p><% } %>
        </div>

        <div class="form-row">
          <label for="lastName">Apellidos</label>
          <input id="lastName" name="lastName" type="text" required value="<%= formData.lastName %>" />
          <% if (errors.lastName) { %><p class="field-error"><%= errors.lastName %></p><% } %>
        </div>

        <div class="form-row">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" required value="<%= formData.email %>" />
          <% if (errors.email) { %><p class="field-error"><%= errors.email %></p><% } %>
        </div>

        <div class="form-row">
          <label for="phone">Telefono del responsable</label>
          <input id="phone" name="phone" type="tel" value="<%= formData.phone %>" />
          <% if (errors.phone) { %><p class="field-error"><%= errors.phone %></p><% } %>
        </div>

        <div class="form-row">
          <label for="password">Contraseña</label>
          <input id="password" name="password" type="password" required minlength="8" />
          <% if (errors.password) { %><p class="field-error"><%= errors.password %></p><% } %>
        </div>

        <div class="form-row">
          <label for="passwordConfirm">Confirmar contraseña</label>
          <input id="passwordConfirm" name="passwordConfirm" type="password" required minlength="8" />
          <% if (errors.passwordConfirm) { %><p class="field-error"><%= errors.passwordConfirm %></p><% } %>
        </div>

        <h2>Datos de la entidad</h2>

        <div class="form-row">
          <label for="organizationName">Nombre de entidad</label>
          <input id="organizationName" name="organizationName" type="text" required value="<%= formData.organizationName %>" />
          <% if (errors.organizationName) { %><p class="field-error"><%= errors.organizationName %></p><% } %>
        </div>

        <div class="form-row">
          <label for="legalName">Razon social o nombre legal</label>
          <input id="legalName" name="legalName" type="text" required value="<%= formData.legalName %>" />
          <% if (errors.legalName) { %><p class="field-error"><%= errors.legalName %></p><% } %>
        </div>

        <div class="form-row">
          <label for="taxId">CIF/NIF</label>
          <input id="taxId" name="taxId" type="text" required value="<%= formData.taxId %>" />
          <% if (errors.taxId) { %><p class="field-error"><%= errors.taxId %></p><% } %>
        </div>

        <div class="form-row">
          <label for="contactPhone">Telefono de contacto</label>
          <input id="contactPhone" name="contactPhone" type="tel" required value="<%= formData.contactPhone %>" />
          <% if (errors.contactPhone) { %><p class="field-error"><%= errors.contactPhone %></p><% } %>
        </div>

        <div class="form-row">
          <label for="city">Ciudad</label>
          <input id="city" name="city" type="text" required value="<%= formData.city %>" />
          <% if (errors.city) { %><p class="field-error"><%= errors.city %></p><% } %>
        </div>

        <div class="form-row">
          <label for="address">Direccion</label>
          <input id="address" name="address" type="text" required value="<%= formData.address %>" />
          <% if (errors.address) { %><p class="field-error"><%= errors.address %></p><% } %>
        </div>

        <%- include("../../partials/address-search", { fieldPrefix: "entityRegistration", formData, errors }) %>

        <div class="form-row">
          <label for="description">Descripcion</label>
          <textarea id="description" name="description" rows="5" required><%= formData.description %></textarea>
          <% if (errors.description) { %><p class="field-error"><%= errors.description %></p><% } %>
        </div>

        <div class="form-row">
          <label for="supportingInfo">Documento o informacion justificativa</label>
          <textarea id="supportingInfo" name="supportingInfo" rows="4"><%= formData.supportingInfo %></textarea>
        </div>

        <button class="primary-button" type="submit">Enviar solicitud</button>
      </form>
    </div>
  </section>
</main>

<%- include("../../partials/footer") %>
