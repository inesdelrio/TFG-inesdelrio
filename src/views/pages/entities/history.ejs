<%- include("../../partials/head") %>
<%- include("../../partials/header") %>

<main class="container dashboard-page">
  <section class="dashboard-hero">
    <h1>Historial de eventos</h1>
    <p>
      Consulta los eventos dados de alta por <%= history.entity.organizationName %>, separados entre proximos y pasados.
    </p>
  </section>

  <section class="event-list">
    <article class="status-card">
      <h2>Eventos futuros</h2>

      <% if (history.futureEvents.length === 0) { %>
        <p>No hay eventos futuros registrados por la entidad.</p>
      <% } %>

      <% history.futureEvents.forEach((event) => { %>
        <%
          const eventStart = new Date(event.startsAt);
          const eventEnd = new Date(event.endsAt || event.startsAt);
          const eventStartDate = eventStart.toLocaleDateString("es-ES");
          const eventEndDate = eventEnd.toLocaleDateString("es-ES");
          const eventStartTime = eventStart.toLocaleTimeString("es-ES", { hour: "2-digit", minute: "2-digit" });
          const eventEndTime = eventEnd.toLocaleTimeString("es-ES", { hour: "2-digit", minute: "2-digit" });
          const eventDateLabel = eventStartDate === eventEndDate
            ? `${eventStartDate}, de ${eventStartTime} a ${eventEndTime}`
            : `Del ${eventStartDate} al ${eventEndDate}, de ${eventStartTime} a ${eventEndTime}`;
        %>
        <div class="history-item">
          <h3><%= event.title %></h3>
          <p><strong>Fecha:</strong> <%= eventDateLabel %></p>
          <p><strong>Ubicacion:</strong> <%= event.city %> - <%= event.address %></p>
          <p><strong>Estado:</strong> <%= event.publicationStatus %></p>
          <p><strong>Inscritos:</strong> <%= event.registrationsCount %> / <%= event.totalSlots %></p>

          <% if (event.canOpenDetail) { %>
            <a class="secondary-link" href="/eventos/<%= event.eventId %>">Ver detalle</a>
          <% } else { %>
            <p class="history-disabled-link">Detalle publico no disponible: evento retirado.</p>
          <% } %>
        </div>
      <% }) %>
    </article>

    <article class="status-card">
      <h2>Eventos pasados</h2>

      <% if (history.pastEvents.length === 0) { %>
        <p>No hay eventos pasados registrados por la entidad.</p>
      <% } %>

      <% history.pastEvents.forEach((event) => { %>
        <%
          const eventStart = new Date(event.startsAt);
          const eventEnd = new Date(event.endsAt || event.startsAt);
          const eventStartDate = eventStart.toLocaleDateString("es-ES");
          const eventEndDate = eventEnd.toLocaleDateString("es-ES");
          const eventStartTime = eventStart.toLocaleTimeString("es-ES", { hour: "2-digit", minute: "2-digit" });
          const eventEndTime = eventEnd.toLocaleTimeString("es-ES", { hour: "2-digit", minute: "2-digit" });
          const eventDateLabel = eventStartDate === eventEndDate
            ? `${eventStartDate}, de ${eventStartTime} a ${eventEndTime}`
            : `Del ${eventStartDate} al ${eventEndDate}, de ${eventStartTime} a ${eventEndTime}`;
        %>
        <div class="history-item">
          <h3><%= event.title %></h3>
          <p><strong>Fecha:</strong> <%= eventDateLabel %></p>
          <p><strong>Ubicacion:</strong> <%= event.city %> - <%= event.address %></p>
          <p><strong>Estado:</strong> <%= event.publicationStatus %></p>
          <p><strong>Inscritos:</strong> <%= event.registrationsCount %> / <%= event.totalSlots %></p>

          <% if (event.canOpenDetail) { %>
            <a class="secondary-link" href="/eventos/<%= event.eventId %>">Ver detalle</a>
          <% } else { %>
            <p class="history-disabled-link">Detalle publico no disponible: evento retirado.</p>
          <% } %>
        </div>
      <% }) %>
    </article>
  </section>
</main>

<%- include("../../partials/footer") %>
