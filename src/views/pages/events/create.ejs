<%- include("../../partials/head") %>
<%- include("../../partials/header") %>

<main class="container dashboard-page">
  <section class="dashboard-hero">
    <h1>Publicar evento</h1>
    <p>
      Crea una actividad desde tu cuenta de entidad para que aparezca en el
      listado publico de voluntariado.
    </p>
  </section>

  <section class="profile-shell">
    <div class="status-card">
      <h2>Estado de publicacion</h2>
      <% if (entity) { %>
        <p><strong>Entidad:</strong> <%= entity.organizationName %></p>
        <p><strong>Validacion:</strong> <%= entity.validationStatus %></p>
      <% } else { %>
        <p>No se ha encontrado una entidad vinculada a la sesion actual.</p>
      <% } %>
      <p class="field-help">
        Solo las entidades en estado <strong>VERIFICADA</strong> pueden publicar eventos.
      </p>
    </div>

    <div class="auth-card">
      <% if (blockedReason) { %>
        <div class="feedback-banner error">
          <strong>Publicacion bloqueada.</strong>
          <p><%= blockedReason %></p>
        </div>
      <% } %>

      <% if (Object.keys(errors).length > 0) { %>
        <div class="feedback-banner error">
          <strong>No se ha podido publicar el evento.</strong>
          <p>Revisa los campos marcados antes de volver a intentarlo.</p>
        </div>
      <% } %>

      <form class="auth-form" action="/eventos" method="post" novalidate>
        <div class="form-row">
          <label for="title">Titulo</label>
          <input id="title" name="title" type="text" required minlength="5" value="<%= formData.title %>" />
          <% if (errors.title) { %><p class="field-error"><%= errors.title %></p><% } %>
        </div>

        <div class="form-row">
          <label for="description">Descripcion</label>
          <textarea id="description" name="description" rows="6" required><%= formData.description %></textarea>
          <% if (errors.description) { %><p class="field-error"><%= errors.description %></p><% } %>
        </div>

        <input name="city" type="hidden" value="Madrid" />
        <% if (errors.city) { %><p class="field-error"><%= errors.city %></p><% } %>

        <%- include("../../partials/address-search", {
          fieldPrefix: "eventCreate",
          title: "Dirección del evento en Madrid",
          includeAddressHidden: true,
          formData,
          errors
        }) %>
        <% if (errors.address) { %><p class="field-error"><%= errors.address %></p><% } %>

        <div class="event-datetime-grid">
          <div class="form-row">
            <label for="startDate">Fecha de inicio</label>
            <input id="startDate" name="startDate" type="date" required value="<%= formData.startDate %>" />
            <% if (errors.startDate) { %><p class="field-error"><%= errors.startDate %></p><% } %>
          </div>

          <div class="form-row">
            <label for="startTime">Hora de inicio</label>
            <input id="startTime" name="startTime" type="time" required value="<%= formData.startTime %>" />
            <% if (errors.startTime) { %><p class="field-error"><%= errors.startTime %></p><% } %>
          </div>

          <div class="form-row">
            <label for="endDate">Fecha de finalización</label>
            <input id="endDate" name="endDate" type="date" value="<%= formData.endDate %>" />
            <% if (errors.endDate) { %><p class="field-error"><%= errors.endDate %></p><% } %>
          </div>

          <div class="form-row">
            <label for="endTime">Hora de fin</label>
            <input id="endTime" name="endTime" type="time" required value="<%= formData.endTime %>" />
            <% if (errors.endTime) { %><p class="field-error"><%= errors.endTime %></p><% } %>
          </div>
        </div>

        <div class="form-row">
          <label for="totalSlots">Plazas</label>
          <input id="totalSlots" name="totalSlots" type="number" min="1" required value="<%= formData.totalSlots %>" />
          <% if (errors.totalSlots) { %><p class="field-error"><%= errors.totalSlots %></p><% } %>
        </div>

        <div class="profile-actions">
          <button class="primary-button" type="submit" <%= blockedReason ? "disabled" : "" %>>Publicar evento</button>
          <a class="secondary-link" href="/eventos">Ver listado publico</a>
        </div>
      </form>
    </div>
  </section>
</main>

<%- include("../../partials/footer") %>
