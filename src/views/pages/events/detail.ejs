<%- include("../../partials/head") %>
<%- include("../../partials/header") %>

<main class="container dashboard-page">
  <section class="dashboard-hero">
    <h1><%= event.title %></h1>
    <% if (!Array.isArray(registrations)) { %>
      <p>
        Consulta el detalle completo de la actividad y la informacion de la entidad organizadora.
      </p>
    <% } %>
  </section>

  <% if (infoMessage) { %>
    <div class="feedback-banner success">
      <strong>Estado actualizado.</strong>
      <p><%= infoMessage %></p>
    </div>
  <% } %>

  <% if (Array.isArray(registrations)) { %>
    <section>
      <p><strong>Fecha y hora:</strong> <%= new Date(event.startsAt).toLocaleString("es-ES") %></p>
      <p><strong>Ubicacion:</strong> <%= event.city %>, <%= event.address %></p>
      <p><strong>Plazas:</strong> <%= availableSlots %> disponibles de <%= event.totalSlots %></p>

      <% if (event.publicationStatus === "RETIRADO") { %>
        <p class="registration-state registration-state-full">Evento retirado.</p>
      <% } else if (availableSlots === 0) { %>
        <p class="registration-state registration-state-full">Evento completo. No quedan plazas disponibles.</p>
      <% } %>

      <p><%= event.description %></p>
    </section>
  <% } else { %>
  <section class="event-detail-grid">
    <article class="status-card">
      <h2>Datos del evento</h2>
      <p><strong>Fecha y hora:</strong> <%= new Date(event.startsAt).toLocaleString("es-ES") %></p>
      <p><strong>Ciudad:</strong> <%= event.city %></p>
      <p><strong>Direccion:</strong> <%= event.address %></p>
      <p><strong>Plazas totales:</strong> <%= event.totalSlots %></p>
      <p><strong>Plazas disponibles:</strong> <%= availableSlots %></p>
      <% if (availableSlots === 0) { %>
        <p class="registration-state registration-state-full">Evento completo. No quedan plazas disponibles.</p>
      <% } %>
      <p><%= event.description %></p>

      <% if (canRegister) { %>
        <% if (isRegistered) { %>
          <p class="registration-state">Ya estas inscrito en esta actividad.</p>
          <form class="subscription-form" action="/eventos/<%= event.id %>/cancelar-inscripcion" method="post">
            <input type="hidden" name="redirectTo" value="/eventos/<%= event.id %>" />
            <button class="danger-button" type="submit">Cancelar inscripcion</button>
          </form>
        <% } else if (availableSlots > 0) { %>
          <form class="subscription-form" action="/eventos/<%= event.id %>/inscribirse" method="post">
            <input type="hidden" name="redirectTo" value="/eventos/<%= event.id %>" />
            <button class="primary-button" type="submit">Apuntarse</button>
          </form>
        <% } %>
      <% } %>
    </article>

    <article class="status-card">
      <h2>Entidad organizadora</h2>
      <p><strong><%= event.entity.organizationName %></strong></p>
      <p><strong>Email:</strong> <%= event.entity.contactEmail %></p>
      <p><strong>Telefono:</strong> <%= event.entity.contactPhone %></p>
      <p><strong>Ciudad:</strong> <%= event.entity.city %></p>
      <p><strong>Direccion:</strong> <%= event.entity.address %></p>
      <p><%= event.entity.description %></p>

      <% if (canSubscribe) { %>
        <% if (isSubscribed) { %>
          <p class="subscription-state">Ya sigues a esta entidad.</p>
          <form class="subscription-form" action="/entidades/<%= event.entity.id %>/dejar-de-seguir" method="post">
            <input type="hidden" name="redirectTo" value="/eventos/<%= event.id %>" />
            <button class="danger-button" type="submit">Dejar de seguir</button>
          </form>
        <% } else { %>
          <form class="subscription-form" action="/entidades/<%= event.entity.id %>/suscribirse" method="post">
            <input type="hidden" name="redirectTo" value="/eventos/<%= event.id %>" />
            <button class="primary-button" type="submit">Seguir entidad</button>
          </form>
        <% } %>
      <% } %>
    </article>
  </section>
  <% } %>

  <% if (Array.isArray(registrations)) { %>
    <section class="dashboard-section">
      <div class="section-heading">
        <h2>Personas inscritas</h2>
        <p><%= registrations.length %> inscrito(s) de <%= event.totalSlots %> plazas.</p>
      </div>

      <% if (registrations.length === 0) { %>
        <p>Todavia no hay personas inscritas.</p>
      <% } else { %>
        <div class="attendees-list">
          <% registrations.forEach((registration) => { %>
            <article class="status-card attendee-card">
              <h3><%= registration.volunteerUser.firstName %> <%= registration.volunteerUser.lastName %></h3>
              <p><strong>Email:</strong> <%= registration.volunteerUser.email %></p>
              <% if (registration.volunteerUser.phone) { %>
                <p><strong>Telefono:</strong> <%= registration.volunteerUser.phone %></p>
              <% } %>
            </article>
          <% }) %>
        </div>
      <% } %>
    </section>
  <% } %>
</main>

<% if (redirectBackToEventsOnBack || redirectBackToNotificationsOnBack) { %>
  <script>
    (() => {
      if (!window.history || !window.history.pushState) {
        return;
      }

      const redirectPath = <%- JSON.stringify(
        redirectBackToNotificationsOnBack ? "/notificaciones" : "/eventos"
      ) %>;
      const marker = { redirectPath };
      window.history.replaceState(marker, "", window.location.href);
      window.history.pushState(marker, "", window.location.href);
      window.addEventListener("popstate", () => {
        window.location.replace(redirectPath);
      });
    })();
  </script>
<% } %>

<%- include("../../partials/footer") %>
