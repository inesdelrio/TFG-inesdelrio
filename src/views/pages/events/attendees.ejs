<%- include("../../partials/head") %>
<%- include("../../partials/header") %>

<main class="container dashboard-page">
  <section class="dashboard-hero">
    <h1>Inscritos en <%= event.title %></h1>
    <p>
      <%= new Date(event.startsAt).toLocaleString("es-ES") %> -
      <%= registrations.length %> inscrito(s) de <%= event.totalSlots %> plazas.
    </p>
  </section>

  <% if (registrations.length === 0) { %>
    <div class="status-card">
      <h2>Sin inscritos</h2>
      <p>Todavia no hay voluntarios apuntados a esta actividad.</p>
    </div>
  <% } else { %>
    <section class="attendees-list">
      <% registrations.forEach((registration) => { %>
        <article class="status-card attendee-card">
          <h2><%= registration.volunteerUser.firstName %> <%= registration.volunteerUser.lastName %></h2>
          <p><strong>Email:</strong> <%= registration.volunteerUser.email %></p>
          <p><strong>Telefono:</strong> <%= registration.volunteerUser.phone || "No informado" %></p>
          <p><strong>Inscrito el:</strong> <%= new Date(registration.createdAt).toLocaleString("es-ES") %></p>
        </article>
      <% }) %>
    </section>
  <% } %>
</main>

<%- include("../../partials/footer") %>
